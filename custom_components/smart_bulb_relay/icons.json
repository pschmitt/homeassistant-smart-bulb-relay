{
  "integration": "mdi:lightbulb-auto",
  "entity": {
    "binary_sensor": {
      "bulb_status": {
        "default": "mdi:lightbulb-outline",
        "state": {
          "on": "mdi:lightbulb-on",
          "off": "mdi:lightbulb-off-outline"
        }
      }
    },
    "button": {
      "power_cycle": {
        "default": "mdi:restart"
      },
      "factory_reset": {
        "default": "mdi:restore"
      }
    },
    "switch": {
      "smart_mode": {
        "default": "mdi:brain"
      }
    }
  }
}
